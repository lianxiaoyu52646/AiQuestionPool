# AI API 配置（可选）
# 题库浏览、真题模考、FSRS刷题学习不需要配置此项
# 仅 PDF 上传 + AI 自动提取题目功能需要

UPSTREAM_API_KEY=你的API密钥
UPSTREAM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
MODEL_NAME=glm-4

# 文件大小限制（字节）
MAX_FILE_SIZE=52428800

# FSRS 间隔重复算法参数
FSRS_W=[0.4,0.6,2.4,5.8,4.93,0.94,0.86,0.01,1.49,0.14,0.94,2.18,0.05,0.34,1.26,0.29,2.61]
